@page "/proyectos"

<section class="py-5 bg-dark">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="p-2 bg-black rounded shadow-lg border border-secondary">
                    <div class="p-5 text-center">
                        <h1 class="display-3 fw-black text-danger mb-0">TIMORUFE</h1>
                        <p class="text-white tracking-widest small">FACTURACIÓN ELECTRÓNICA</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
