@page "/servicios"

<section class="py-32 px-6 bg-[#161616]">
    <div class="max-w-7xl mx-auto">
        <div class="mb-16">
            <h2 class="text-[#A82D1F] font-black text-4xl mb-2 uppercase tracking-tighter">QUÉ_HACEMOS</h2>
            <div class="h-1 w-20 bg-[#A82D1F]"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @foreach (var servicio in listaServicios)
            {
                <div class="p-8 border border-white/5 hover:border-[#A82D1F]/50 transition-all bg-black/40 group relative overflow-hidden">
                    <div class="mb-6 text-[#A82D1F] transform group-hover:scale-110 transition-transform duration-300">
                        @((MarkupString)servicio.Icono)
                    </div>
                    <h3 class="text-xl font-bold mb-4">@servicio.Titulo</h3>
                    <p class="opacity-60 text-sm leading-relaxed">@servicio.Descripcion</p>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private List<Servicio> listaServicios = new()
    {
        new ("Software Architecture", "Sistemas robustos bajo la disciplina Shinobi. Código limpio que resiste cualquier asalto.", "<svg class='w-12 h-12' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'></path></svg>"),
        new ("Cybersecurity", "Protegemos tu realidad digital. Defensas impenetrables inspiradas en Fsociety.", "<svg class='w-12 h-12' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'></path></svg>"),
        new ("UI/UX Flow", "Diseños con el ritmo de Avicii. Interfaces fluidas que armonizan estética y funcionalidad.", "<svg class='w-12 h-12' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3'></path></svg>")
    };

    record Servicio(string Titulo, string Descripcion, string Icono);
}